<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.ncu.onlinechat.module.user.mapper.UserMapper">

    <resultMap id="UserMap" type="cn.edu.ncu.onlinechat.module.user.entity.User">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="password" property="password" />
        <result column="nickname" property="nickname" />
        <result column="avatar" property="avatar" />
        <result column="email" property="email" />
        <result column="phone" property="phone" />
        <result column="signature" property="signature" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <select id="selectById" resultMap="UserMap">
        SELECT *
        FROM t_user
        WHERE id = #{id}
    </select>

    <select id="selectByUsername" resultMap="UserMap">
        SELECT *
        FROM t_user
        WHERE username = #{username}
    </select>

    <select id="selectByPhone" resultMap="UserMap">
        SELECT *
        FROM t_user
        WHERE phone = #{phone}
    </select>

    <select id="searchByKeyword" resultMap="UserMap">
        SELECT *
        FROM t_user
        WHERE username LIKE CONCAT('%', #{keyword}, '%')
           OR nickname LIKE CONCAT('%', #{keyword}, '%')
           OR phone LIKE CONCAT('%', #{keyword}, '%')
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_user
        (username, password, nickname, avatar, email, phone, signature, status)
        VALUES
        (#{username}, #{password}, #{nickname}, #{avatar}, #{email}, #{phone}, #{signature}, #{status})
    </insert>

    <update id="update">
        UPDATE t_user
        SET username = #{username},
            password = #{password},
            nickname = #{nickname},
            avatar = #{avatar},
            email = #{email},
            phone = #{phone},
            signature = #{signature},
            status = #{status}
        WHERE id = #{id}
    </update>

    <update id="updatePassword">
        UPDATE t_user
        SET password = #{password}
        WHERE id = #{id}
    </update>

</mapper>
